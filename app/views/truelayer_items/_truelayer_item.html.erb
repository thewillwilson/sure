<%# locals: (truelayer_item:) %>

<%= tag.div id: dom_id(truelayer_item) do %>
  <details open class="group bg-container p-4 shadow-border-xs rounded-xl">
    <summary class="flex items-center justify-between gap-2 focus-visible:outline-hidden">
      <div class="flex items-center gap-2">
        <%= icon "chevron-right", class: "group-open:transform group-open:rotate-90" %>

        <div class="flex items-center justify-center h-8 w-8 bg-success/10 rounded-full">
          <div class="flex items-center justify-center">
            <%= tag.p truelayer_item.name.first.upcase, class: "text-success text-xs font-medium" %>
          </div>
        </div>

        <div class="pl-1 text-sm">
          <div class="flex items-center gap-2">
            <%= tag.p truelayer_item.display_name, class: "font-medium text-primary" %>
            <% if truelayer_item.scheduled_for_deletion? %>
              <p class="text-destructive text-sm animate-pulse"><%= t(".deletion_in_progress") %></p>
            <% end %>
          </div>
          <p class="text-xs text-secondary"><%= t(".provider_name") %></p>
          <% if truelayer_item.consent_expires_at.present? %>
            <p class="text-xs <%= truelayer_item.consent_expiring_soon? ? "text-warning font-medium" : "text-secondary" %>">
              <%= t(".consent_expires", date: truelayer_item.consent_expires_at.to_date.to_fs(:long)) %>
            </p>
          <% end %>
          <% if truelayer_item.syncing? %>
            <div class="text-secondary flex items-center gap-1">
              <%= icon "loader", size: "sm", class: "animate-spin" %>
              <%= tag.span t(".syncing") %>
            </div>
          <% elsif truelayer_item.requires_update? %>
            <div class="text-warning flex items-center gap-1">
              <%= icon "alert-triangle", size: "sm", color: "warning" %>
              <%= tag.span t(".reconnect_required") %>
            </div>
          <% elsif truelayer_item.token_lapsed? %>
            <div class="text-warning flex items-center gap-1">
              <%= icon "alert-triangle", size: "sm", color: "warning" %>
              <%= tag.span t(".token_expired") %>
            </div>
          <% else %>
            <p class="text-secondary">
              <% if truelayer_item.last_synced_at %>
                <%= t(".last_synced", time: time_ago_in_words(truelayer_item.last_synced_at)) %>
              <% else %>
                <%= t(".never_synced") %>
              <% end %>
            </p>
          <% end %>
        </div>
      </div>

      <% if Current.user&.admin? %>
        <div class="flex items-center gap-2">
          <% if truelayer_item.requires_update? %>
            <%= button_to reauthorize_truelayer_item_path(truelayer_item),
                          method: :post,
                          class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-lg text-white bg-warning hover:opacity-90 transition-colors",
                          data: { turbo: false } do %>
              <%= icon "refresh-cw", size: "sm" %>
              <%= t(".reconnect") %>
            <% end %>
          <% elsif truelayer_item.token_lapsed? %>
            <%= button_to refresh_token_truelayer_item_path(truelayer_item),
                          method: :post,
                          class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-lg text-white bg-warning hover:opacity-90 transition-colors" do %>
              <%= icon "refresh-cw", size: "sm" %>
              <%= t(".reconnect") %>
            <% end %>
          <% elsif !truelayer_item.scheduled_for_deletion? %>
            <%= button_to sync_truelayer_item_path(truelayer_item),
                          method: :post,
                          class: "inline-flex items-center gap-1 px-3 py-1.5 text-sm font-medium rounded-lg text-primary bg-container border border-primary hover:bg-gray-50 transition-colors" do %>
              <%= icon "refresh-cw", size: "sm" %>
              <%= t(".sync") %>
            <% end %>
          <% end %>

          <%= render DS::Menu.new do |menu| %>
            <% menu.with_item(
              variant: "button",
              text: t(".delete"),
              icon: "trash-2",
              href: truelayer_item_path(truelayer_item),
              method: :delete,
              confirm: CustomConfirm.for_resource_deletion(truelayer_item.name, high_severity: true)
            ) %>
          <% end %>
        </div>
      <% end %>
    </summary>

    <% unless truelayer_item.scheduled_for_deletion? %>
      <div class="space-y-4 mt-4">
        <% if truelayer_item.accounts.any? %>
          <%= render "accounts/index/account_groups", accounts: truelayer_item.accounts %>
        <% end %>

        <% latest_sync = truelayer_item.syncs.ordered.first %>
        <% stats = latest_sync&.sync_stats || {} %>
        <% latest_sync_error = latest_sync&.error %>
        <% if latest_sync_error.present? && stats.is_a?(Hash) %>
          <% stats = stats.merge(
            "total_errors" => 1,
            "errors" => [ { "message" => latest_sync_error } ]
          ) %>
        <% end %>
        <%= render ProviderSyncSummary.new(
          stats: stats,
          provider_item: truelayer_item
        ) %>

        <% if !truelayer_item.syncing? && truelayer_item.unlinked_accounts_count > 0 %>
          <div class="p-4 flex flex-col gap-3 items-center justify-center">
            <p class="text-primary font-medium text-sm"><%= t(".setup_needed") %></p>
            <p class="text-secondary text-sm"><%= t(".unlinked_accounts_message", count: truelayer_item.unlinked_accounts_count) %></p>
            <%= render DS::Link.new(
              text: t(".setup_accounts"),
              icon: "settings",
              variant: "primary",
              href: setup_accounts_truelayer_item_path(truelayer_item),
              frame: :modal
            ) %>
          </div>
        <% elsif truelayer_item.skipped_accounts_count > 0 %>
          <div class="p-4 flex flex-col gap-3 items-center justify-center">
            <p class="text-secondary text-sm"><%= t(".skipped_accounts_message", count: truelayer_item.skipped_accounts_count) %></p>
            <%= button_to reset_skipped_truelayer_item_path(truelayer_item),
                          method: :post,
                          class: "text-xs text-secondary underline hover:text-primary",
                          data: { turbo_frame: "modal" } do %>
              <%= t(".review_skipped") %>
            <% end %>
          </div>
        <% elsif truelayer_item.accounts.empty? && truelayer_item.truelayer_accounts.empty? %>
          <div class="p-4 flex flex-col gap-3 items-center justify-center">
            <p class="text-primary font-medium text-sm"><%= t(".no_accounts_found") %></p>
            <p class="text-secondary text-sm"><%= t(".no_accounts_message") %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </details>
<% end %>
