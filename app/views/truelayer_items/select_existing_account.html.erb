<%# Modal: Link an existing TrueLayer account to a manual account %>
<%= turbo_frame_tag "modal" do %>
  <%= render DS::Dialog.new do |dialog| %>
    <% dialog.with_header(title: t(".title")) %>

    <% dialog.with_body do %>
      <% if @available_truelayer_accounts.blank? %>
        <div class="p-4 text-sm text-secondary">
          <p><%= t(".no_accounts") %></p>
        </div>
      <% else %>
        <%= form_with url: link_existing_account_truelayer_items_path, method: :post, class: "space-y-4" do %>
          <%= hidden_field_tag :account_id, @account.id %>
          <div class="space-y-2 max-h-64 overflow-auto">
            <% @available_truelayer_accounts.each do |ta| %>
              <label class="flex items-center gap-3 p-2 rounded border border-surface-inset/50 hover:border-primary cursor-pointer">
                <%= radio_button_tag :truelayer_account_id, ta.id, false, required: true %>
                <div class="flex flex-col">
                  <span class="text-sm text-primary font-medium"><%= ta.name.presence || ta.account_id %></span>
                  <span class="text-xs text-secondary"><%= ta.currency %></span>
                </div>
              </label>
            <% end %>
          </div>

          <div class="flex items-center justify-end gap-2">
            <%= render DS::Button.new(text: t(".link"), variant: :primary, icon: "link-2", type: :submit) %>
            <%= render DS::Link.new(text: t(".cancel"), variant: :secondary, href: accounts_path, data: { turbo_frame: "_top" }) %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  <% end %>
<% end %>
