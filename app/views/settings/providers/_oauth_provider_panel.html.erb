<div class="space-y-4">
  <% config = Current.family.provider_family_configs.find_by(provider_key: provider_key) %>
  <% if config %>
    <% connections = Current.family.provider_connections.where(provider_family_config: config).includes(:provider_accounts) %>
    <% if connections.any? %>
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 bg-success rounded-full"></div>
        <p class="text-sm text-secondary"><%= t("settings.providers.oauth_provider_panel.connected", count: connections.count) %></p>
      </div>
      <% connections.each do |conn| %>
        <div class="flex items-center justify-between p-3 rounded-lg border border-primary">
          <div class="flex items-center gap-2">
            <span class="text-sm text-primary"><%= conn.institution_name %></span>
            <% if conn.requires_update? %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-destructive/10 text-destructive border border-destructive/20">
                <%= icon("alert-circle", class: "w-3 h-3 shrink-0") %>
                <%= t("settings.providers.oauth_provider_panel.requires_reauth") %>
              </span>
            <% elsif conn.disconnected? %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-destructive/10 text-destructive border border-destructive/20">
                <%= icon("alert-circle", class: "w-3 h-3 shrink-0") %>
                <%= t("settings.providers.oauth_provider_panel.disconnected") %>
              </span>
            <% else %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-success/10 text-success">
                <%= t("settings.providers.oauth_provider_panel.status_good") %>
              </span>
            <% end %>
          </div>
          <div class="flex items-center gap-2">
            <% if conn.requires_update? %>
              <%= button_to t("settings.providers.oauth_provider_panel.reconnect"),
                            reauth_provider_connection_path(conn),
                            method: :post,
                            data: { turbo: false },
                            class: "text-sm px-3 py-1.5 rounded-lg bg-destructive text-inverse hover:opacity-90 transition-opacity shrink-0" %>
            <% end %>
            <%= link_to t("settings.providers.oauth_provider_panel.manage"), provider_connection_path(conn), class: "text-sm link", data: { turbo_frame: "_top" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 bg-secondary rounded-full"></div>
        <p class="text-sm text-secondary"><%= t("settings.providers.oauth_provider_panel.configured_not_connected") %></p>
      </div>
    <% end %>
    <div class="flex gap-2">
      <%= button_to t("settings.providers.oauth_provider_panel.add_connection"),
                    new_oauth_callbacks_path(provider: provider_key),
                    method: :post,
                    data: { turbo: false },
                    class: "btn btn-sm" %>
      <%= link_to t("settings.providers.oauth_provider_panel.edit_credentials"),
                  edit_provider_family_config_path(config),
                  class: "btn btn-sm",
                  data: { turbo_frame: "_top" } %>
    </div>
  <% else %>
    <div class="flex items-center gap-2">
      <div class="w-2 h-2 bg-secondary rounded-full"></div>
      <p class="text-sm text-secondary"><%= t("settings.providers.oauth_provider_panel.not_configured") %></p>
    </div>
    <%= link_to t("settings.providers.oauth_provider_panel.configure"),
                new_provider_family_config_path(provider: provider_key),
                class: "btn btn-sm",
                data: { turbo_frame: "_top" } %>
  <% end %>
</div>
