<%= content_for :page_title, t(".title") %>

<div class="space-y-4">
  <%= settings_section title: t(".login_behaviour.title") do %>
    <%= styled_form_with model: Setting.new,
                         url: update_settings_admin_sso_providers_path,
                         method: :patch,
                         data: { controller: "auto-submit-form", auto_submit_form_trigger_event_value: "change" } do |form| %>
      <!-- Local login toggle -->
      <div class="flex items-center justify-between">
        <div class="space-y-1">
          <p class="text-sm font-medium text-primary"><%= t(".login_behaviour.local_login_label") %></p>
          <p class="text-secondary text-sm"><%= t(".login_behaviour.local_login_help") %></p>
        </div>

        <%= form.toggle :local_login_enabled,
                        checked: Setting.local_login_enabled,
                        data: { auto_submit_form_target: "auto" } %>
      </div>

      <!-- Auto-redirect toggle (visually dimmed until local login is off) -->
      <div class="flex items-center justify-between <%= 'opacity-50' if Setting.local_login_enabled %>">
        <div class="space-y-1">
          <p class="text-sm font-medium text-primary"><%= t(".login_behaviour.auto_redirect_label") %></p>
          <p class="text-secondary text-sm"><%= t(".login_behaviour.auto_redirect_help") %></p>
        </div>

        <%= form.toggle :sso_auto_redirect,
                        checked: Setting.sso_auto_redirect,
                        disabled: Setting.local_login_enabled,
                        data: { auto_submit_form_target: "auto" } %>
      </div>
    <% end %>
  <% end %>

  <p class="text-secondary mb-4">
    <%= t(".description") %>
    <% unless FeatureFlags.db_sso_providers? %>
      <span class="text-warning"><%= t(".configuration_mode.restart_notice") %></span>
    <% end %>
  </p>

  <%= settings_section title: t(".configured_providers_title") do %>
    <% if @sso_providers.any? %>
      <div class="divide-y divide-primary">
        <% @sso_providers.each do |provider| %>
          <div class="flex items-center justify-between py-3 first:pt-0 last:pb-0">
            <div class="flex items-center gap-3">
              <% if provider.icon.present? %>
                <%= icon provider.icon, class: "w-5 h-5 text-secondary" %>
              <% else %>
                <%= icon "key", class: "w-5 h-5 text-secondary" %>
              <% end %>
              <div>
                <p class="font-medium text-primary"><%= provider.label %></p>
                <p class="text-sm text-secondary"><%= provider.strategy.titleize %> &middot; <%= provider.name %></p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <% if provider.enabled? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                  <%= t(".table.enabled") %>
                </span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-surface text-secondary">
                  <%= t(".table.disabled") %>
                </span>
              <% end %>
              <%= link_to edit_admin_sso_provider_path(provider), class: "p-1 text-secondary hover:text-primary", title: t(".actions.edit") do %>
                <%= icon "pencil", class: "w-4 h-4" %>
              <% end %>
              <%= button_to toggle_admin_sso_provider_path(provider), method: :patch, class: "p-1 text-secondary hover:text-primary", title: provider.enabled? ? t(".actions.disable") : t(".actions.enable"), form: { data: { turbo_confirm: t(provider.enabled? ? ".confirm.disable" : ".confirm.enable") } } do %>
                <%= icon provider.enabled? ? "toggle-right" : "toggle-left", class: "w-4 h-4" %>
              <% end %>
              <%= button_to admin_sso_provider_path(provider), method: :delete, class: "p-1 text-destructive hover:text-destructive", title: t(".actions.delete"), form: { data: { turbo_confirm: t(".confirm.delete") } } do %>
                <%= icon "trash-2", class: "w-4 h-4" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-6">
        <%= icon "key", class: "w-12 h-12 mx-auto text-secondary mb-3" %>
        <p class="text-secondary"><%= t(".empty_state") %></p>
      </div>
    <% end %>

    <div class="pt-4 border-t border-primary">
      <%= link_to new_admin_sso_provider_path, class: "inline-flex items-center gap-2 text-sm font-medium text-primary hover:text-secondary" do %>
        <%= icon "plus", class: "w-4 h-4" %>
        <%= t(".add_provider") %>
      <% end %>
    </div>
  <% end %>

  <% if @legacy_providers.any? %>
    <%= settings_section title: t("admin.sso_providers.index.legacy_providers_title"), collapsible: true, open: true do %>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 mb-4">
        <div class="flex gap-2">
          <%= icon "alert-triangle", class: "w-5 h-5 text-amber-600 shrink-0" %>
          <p class="text-sm text-amber-800">
            <%= t("admin.sso_providers.index.legacy_providers_notice") %>
          </p>
        </div>
      </div>

      <div class="divide-y divide-primary">
        <% @legacy_providers.each do |provider| %>
          <div class="flex items-center justify-between py-3 first:pt-0 last:pb-0">
            <div class="flex items-center gap-3">
              <% provider_icon = provider[:icon].presence || "key" %>
              <%= icon provider_icon, class: "w-5 h-5 text-secondary" %>
              <div>
                <p class="font-medium text-primary"><%= provider[:label].presence || provider[:name] %></p>
                <p class="text-sm text-secondary">
                  <%= provider[:strategy].to_s.titleize %> &middot; <%= provider[:name] %>
                  <% if provider[:issuer].present? %>
                    &middot; <span class="text-xs"><%= provider[:issuer] %></span>
                  <% end %>
                </p>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">
                <%= t("admin.sso_providers.index.env_configured") %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= settings_section title: t(".configuration_mode.title"), collapsible: true, open: false do %>
    <div class="space-y-3">
      <div class="flex items-center justify-between">
        <div>
          <p class="font-medium text-primary"><%= t(".configuration_mode.db_providers") %></p>
          <p class="text-sm text-secondary"><%= t(".configuration_mode.db_providers_help") %></p>
        </div>
        <% if FeatureFlags.db_sso_providers? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
            <%= t(".table.enabled") %>
          </span>
        <% else %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-surface text-secondary">
            <%= t(".table.disabled") %>
          </span>
        <% end %>
      </div>
      <p class="text-sm text-secondary">
        <%= t(".configuration_mode.env_hint", env_var: "AUTH_PROVIDERS_SOURCE=db") %>
      </p>
    </div>
  <% end %>
</div>
