<%= turbo_frame_tag "modal" do %>
  <%= render DS::Dialog.new do |dialog| %>
    <% if @configured %>
      <% dialog.with_header(title: t(".title_connect", provider: @provider_key.titleize)) %>
      <% dialog.with_body do %>
        <p class="text-sm text-secondary mb-4"><%= t(".connect_description", provider: @provider_key.titleize) %></p>
        <%= button_to t(".connect_button", provider: @provider_key.titleize),
                      new_oauth_callbacks_path(provider: @provider_key),
                      method: :post,
                      data: { turbo: false },
                      class: "inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-medium text-inverse bg-inverse hover:bg-inverse-hover transition-colors" %>
      <% end %>
    <% else %>
      <% dialog.with_header(title: t(".title_setup_required", provider: @provider_key.titleize)) %>
      <% dialog.with_body do %>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <%= icon("alert-circle", class: "text-warning w-5 h-5 shrink-0 mt-0.5") %>
            <div class="text-sm text-secondary">
              <p class="font-medium text-primary mb-1"><%= t(".not_configured_heading") %></p>
              <p><%= t(".not_configured_body", provider: @provider_key.titleize) %></p>
            </div>
          </div>

          <div class="bg-surface rounded-lg p-4 space-y-2 text-sm">
            <p class="font-medium text-primary"><%= t(".setup_steps_heading") %></p>
            <ol class="list-decimal list-inside space-y-1 text-secondary">
              <li><%= t(".setup_step_1") %></li>
              <li><%= t(".setup_step_2", provider: @provider_key.titleize) %></li>
              <li><%= t(".setup_step_3") %></li>
            </ol>
          </div>

          <%= link_to t(".go_to_settings"),
                      settings_providers_path,
                      class: "inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-medium text-inverse bg-inverse hover:bg-inverse-hover transition-colors",
                      data: { turbo_frame: "_top" } %>
        </div>
      <% end %>
    <% end %>
  <% end %>
<% end %>
