<%# Mounts the Plaid JS controller. flow_id ties this render to the session
    state stashed in #new or #resume, and the JS posts back to
    /provider_connections/plaid/callback with that flow_id so the server can
    consume the right flow record. %>
<%= turbo_frame_tag "modal" do %>
  <%= tag.div data: {
                controller: "plaid",
                plaid_link_token_value: @link_token,
                plaid_region_value: @region,
                plaid_is_update_value: @is_update,
                plaid_is_resume_value: @is_resume,
                plaid_flow_id_value: @flow_id,
                plaid_connection_id_value: @connection&.id
              } %>
<% end %>
